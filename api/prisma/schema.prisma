generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  displayname   String         @unique
  password      String
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  incomingFiles IncomingFile[]
  people        Person[]
  playlists     Playlist[]
  songs         Songs[]
  tags          Tag[]
  userHistories UserHistory[]
  montages      VideoMontage[]
  ratings       VideoRatings[]
  videoSegments VideoSegment[]
}

model IncomingFile {
  id        Int      @id @default(autoincrement())
  filename  String
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  people    String
  tags      String
  user      User     @relation(fields: [userId], references: [id])
}

model ConvertVideo {
  id          Int       @id @default(autoincrement())
  videoFileId Int       @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  videoFile   VideoFile @relation(fields: [videoFileId], references: [id])
}

model VideoFile {
  id            Int            @id @default(autoincrement())
  filename      String
  filepath      String
  size          BigInt
  duration      Int
  height        Int
  width         Int
  videoCodec    String
  audioCodec    String
  views         Int            @default(0)
  convertId     Int?           @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  convertVideo  ConvertVideo?
  playlistItems PlaylistItem[]
  userHistories UserHistory[]
  people        VideoPerson[]
  ratings       VideoRatings[]
  videoSegments VideoSegment[]
  tags          VideoTag[]

  @@unique([filename, size])
}

model Tag {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  userId     Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  creator    User       @relation(fields: [userId], references: [id])
  videoFiles VideoTag[]
}

model Person {
  id         Int           @id @default(autoincrement())
  name       String        @unique
  userId     Int
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  creator    User          @relation(fields: [userId], references: [id])
  videoFiles VideoPerson[]
}

model VideoRatings {
  videoId   Int
  userId    Int
  rating    Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     VideoFile @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([videoId, userId])
}

model Playlist {
  id            Int            @id @default(autoincrement())
  name          String
  userId        Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlistItems PlaylistItem[]
}

model PlaylistItem {
  id         Int       @id @default(autoincrement())
  position   Int
  videoId    Int
  playlistId Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  playlist   Playlist  @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  video      VideoFile @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, playlistId])
  @@unique([playlistId, position])
}

model VideoTag {
  id        Int       @id @default(autoincrement())
  videoId   Int
  tagId     Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  video     VideoFile @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, tagId])
}

model VideoPerson {
  id        Int       @id @default(autoincrement())
  videoId   Int
  personId  Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  person    Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  video     VideoFile @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, personId])
}

model Configuration {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoSegment {
  id           Int                  @id @default(autoincrement())
  userId       Int
  videoFileId  Int
  start        Int
  end          Int
  categoryId   Int
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  category     VideoSegmentCategory @relation(fields: [categoryId], references: [id])
  user         User                 @relation(fields: [userId], references: [id])
  videoFile    VideoFile            @relation(fields: [videoFileId], references: [id])
  VideoMontage VideoMontage[]       @relation("VideoMontageToVideoSegment")
}

model VideoSegmentCategory {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  videoSegments VideoSegment[]
}

model Songs {
  id           Int            @id @default(autoincrement())
  title        String
  artist       String?
  duration     Int
  filepath     String
  userId       Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id])
  VideoMontage VideoMontage[] @relation("SongsToVideoMontage")
}

model VideoMontage {
  id            Int            @id @default(autoincrement())
  name          String
  userId        Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id])
  songs         Songs[]        @relation("SongsToVideoMontage")
  videoSegments VideoSegment[] @relation("VideoMontageToVideoSegment")
}

model UserHistory {
  id          Int       @id @default(autoincrement())
  userId      Int
  videoFileId Int
  watchedAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoFile   VideoFile @relation(fields: [videoFileId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  USER
}
